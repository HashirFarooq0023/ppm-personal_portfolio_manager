# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# --- Clerk ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- API URL ---
# Leave EMPTY locally — Vite proxies /api/ to localhost:8000 automatically.
# On Vercel — leave EMPTY too; vercel.json rewrites /api/ to the Render backend.
# Only set this if you need to override the API base URL explicitly.
VITE_API_URL=
